@model ContactManagerLanMar.Models.Contact

@{
    ViewData["Title"] = "Delete Contact";
}

<h1 class="mb-3 text-danger">Delete Contact</h1>

<div class="alert alert-warning">
    <strong>Are you sure you want to delete this contact?</strong>
</div>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">First Name</dt>
            <dd class="col-sm-9">@Model.FirstName</dd>
            <dt class="col-sm-3">Last Name</dt>
            <dd class="col-sm-9">@Model.LastName</dd>
            <dt class="col-sm-3">Company</dt>
            <dd class="col-sm-9">@Model.CompanyName</dd>
            <dt class="col-sm-3">Mobile</dt>
            <dd class="col-sm-9">@Model.Mobile</dd>
            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>
        </dl>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>